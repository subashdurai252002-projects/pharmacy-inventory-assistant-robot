#!/usr/bin/env python3
import math
import numpy as np
import rclpy
from rclpy.node import Node

from nav_msgs.msg import Odometry
from geometry_msgs.msg import PoseArray

import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation


def _poses_to_xy(msg):
    if msg is None:
        return np.empty((0, 2))
    pts = []
    for p in msg.poses:
        pts.append([p.position.x, p.position.y])
    if len(pts) == 0:
        return np.empty((0, 2))
    return np.array(pts, dtype=float)


class Robot2DViewer(Node):
    def __init__(self):
        super().__init__("robot2d_viewer")

        self.robot_xy = None
        self.robot_yaw = 0.0

        self.objects_msg = None
        self.detected_msg = None
        self.reached_msg = None

        self.create_subscription(Odometry, "/odom", self.cb_odom, 10)
        self.create_subscription(PoseArray, "/objects", self.cb_objects, 10)
        self.create_subscription(PoseArray, "/detected", self.cb_detected, 10)
        self.create_subscription(PoseArray, "/reached", self.cb_reached, 10)

        self.fig, self.ax = plt.subplots()
        self.ax.set_title("Robot2D Viewer (Robot + Objects + Detected)")
        self.ax.set_xlabel("x")
        self.ax.set_ylabel("y")
        self.ax.grid(True)
        self.ax.set_xlim(-10, 30)
        self.ax.set_ylim(-5, 30)

        empty = np.empty((0, 2))
        self.sc_objects = self.ax.scatter(empty[:, 0], empty[:, 1], label="objects")
        self.sc_detected = self.ax.scatter(empty[:, 0], empty[:, 1], label="detected")
        self.sc_robot = self.ax.scatter(empty[:, 0], empty[:, 1], label="robot")
        self.sc_reached = self.ax.scatter(empty[:, 0], empty[:, 1], label="reached")

        self.l_heading, = self.ax.plot([], [], label="heading")
        self.ax.legend(loc="upper right")

        self.ani = FuncAnimation(self.fig, self.update_plot, interval=100, blit=False)
        self.get_logger().info("✅ viewer started")

    def cb_odom(self, msg: Odometry):
        x = msg.pose.pose.position.x
        y = msg.pose.pose.position.y

        q = msg.pose.pose.orientation
        siny_cosp = 2.0 * (q.w * q.z + q.x * q.y)
        cosy_cosp = 1.0 - 2.0 * (q.y * q.y + q.z * q.z)
        self.robot_yaw = math.atan2(siny_cosp, cosy_cosp)

        self.robot_xy = np.array([[x, y]], dtype=float)

    def cb_objects(self, msg: PoseArray):
        self.objects_msg = msg

    def cb_detected(self, msg: PoseArray):
        self.detected_msg = msg

    def cb_reached(self, msg: PoseArray):
        self.reached_msg = msg

    def update_plot(self, _):
        robot_xy = np.empty((0, 2)) if self.robot_xy is None else self.robot_xy

        objects_xy = _poses_to_xy(self.objects_msg)
        detected_xy = _poses_to_xy(self.detected_msg)
        reached_xy = _poses_to_xy(self.reached_msg)

        self.sc_robot.set_offsets(robot_xy)
        self.sc_objects.set_offsets(objects_xy)
        self.sc_detected.set_offsets(detected_xy)
        self.sc_reached.set_offsets(reached_xy)

        if robot_xy.shape[0] == 1:
            x, y = robot_xy[0]
            L = 1.0
            hx = x + L * math.cos(self.robot_yaw)
            hy = y + L * math.sin(self.robot_yaw)
            self.l_heading.set_data([x, hx], [y, hy])
        else:
            self.l_heading.set_data([], [])

        return []


def main():
    rclpy.init()
    node = Robot2DViewer()

    try:
        while rclpy.ok():
            rclpy.spin_once(node, timeout_sec=0.01)
            plt.pause(0.001)
    except KeyboardInterrupt:
        pass

    node.destroy_node()
    rclpy.shutdown()


if __name__ == "__main__":
    main()
